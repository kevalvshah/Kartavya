# Build artifacts — Vercel rebuilds from source on every deploy.
# Committing this directory is what caused the prod outage on May 5, 2026
# (stale index.html referencing JS files that didn't exist).
build/
node_modules/
.next/
out/
dist/

# Dependency lock files belong in the repo, but caches do not
.yarn/cache
.yarn/install-state.gz
.pnp.*

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm/

# Editor / OS junk
.DS_Store
*.local
.idea/
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json

# Env files (never commit secrets)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
