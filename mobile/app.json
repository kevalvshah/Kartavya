{
  "expo": {
    "name": "Kartavya",
    "slug": "kartavya",
    "scheme": "kartavya",
    "version": "2.0.1",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#050e1a"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.aekaminc.kartavya",
      "infoPlist": {
        "NSCameraUsageDescription": "Capture site photos and receipts to attach to tasks.",
        "NSMicrophoneUsageDescription": "Record voice notes that turn into task comments.",
        "NSPhotoLibraryUsageDescription": "Attach photos from your library to tasks.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.aekaminc.kartavya",
      "versionCode": 4,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0082c6"
      },
      "permissions": [
        "android.permission.INTERNET",
        "android.permission.ACCESS_NETWORK_STATE",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.POST_NOTIFICATIONS"
      ]
    },
    "plugins": [
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#05b7aa",
          "defaultChannel": "default",
          "sounds": [
            "./assets/notification.wav"
          ]
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Kartavya to attach photos to tasks.",
          "cameraPermission": "Allow Kartavya to capture photos for tasks."
        }
      ],
      "expo-av",
      "expo-document-picker"
    ],
    "extra": {
      "eas": {
        "projectId": "196c2be9-caab-49a6-a359-a2adbfc6d821"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/196c2be9-caab-49a6-a359-a2adbfc6d821",
      "enabled": true,
      "fallbackToCacheTimeout": 0,
      "checkAutomatically": "ON_LOAD"
    },
    "owner": "aekaminc"
  }
}
