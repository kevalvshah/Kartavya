{
  "expo": {
    "name": "Kartavya",
    "slug": "kartavya",
    "owner": "aekaminc",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "kartavya",
    "backgroundColor": "#050e1a",
    "primaryColor": "#0082c6",
    "userInterfaceStyle": "dark",
    "splash": {
      "backgroundColor": "#050e1a",
      "resizeMode": "contain",
      "image": "./assets/splash.png"
    },
    "icon": "./assets/icon.png",
    "android": {
      "package": "com.aekaminc.kartavya",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#050e1a"
      }
    },
    "ios": {
      "bundleIdentifier": "com.aekaminc.kartavya",
      "supportsTablet": true
    },
    "plugins": [
      "expo-font",
      "expo-splash-screen"
    ],
    "extra": {
      "eas": {
        "projectId": "196c2be9-caab-49a6-a359-a2adbfc6d821"
      }
    }
  }
}
