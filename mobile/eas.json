{
  "cli": {
    "version": ">= 12.0.0",
    "requireCommit": true,
    "appVersionSource": "local"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "ios": {
        "simulator": false
      },
      "android": {
        "buildType": "apk",
        "gradleCommand": ":app:assembleDebug"
      },
      "env": {
        "APP_ENV": "development",
        "EXPO_PUBLIC_API_URL": "https://kartavya-production.up.railway.app"
      }
    },
    "preview": {
      "distribution": "internal",
      "ios": {
        "simulator": false
      },
      "android": {
        "buildType": "apk"
      },
      "env": {
        "APP_ENV": "preview",
        "EXPO_PUBLIC_API_URL": "https://kartavya-production.up.railway.app"
      }
    },
    "simulator": {
      "distribution": "internal",
      "ios": {
        "simulator": true
      },
      "env": {
        "APP_ENV": "preview",
        "EXPO_PUBLIC_API_URL": "https://kartavya-production.up.railway.app"
      }
    },
    "production": {
      "autoIncrement": true,
      "distribution": "store",
      "ios": {
        "image": "latest"
      },
      "android": {
        "buildType": "app-bundle"
      },
      "env": {
        "APP_ENV": "production",
        "EXPO_PUBLIC_API_URL": "https://kartavya-production.up.railway.app"
        // Future: switch to "https://api.kartavya.aekaminc.com" here only
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        // appleId, ascAppId, appleTeamId moved to EAS secrets
        // Run: eas secret:create --scope project --name EXPO_APPLE_ID --value "keval@aekaminc.com"
        //      eas secret:create --scope project --name EXPO_ASC_APP_ID --value "com.aekaminc.kartavya"
        //      eas secret:create --scope project --name EXPO_APPLE_TEAM_ID --value "AEKAMINC"
      },
      "android": {
        "serviceAccountKeyPath": "./google-service-account.json",
        "track": "internal"
      }
    }
  }
}
