# Kartavya Backend — Environment Variables
# Copy to .env for local dev, set in Railway for production

# Supabase PostgreSQL direct connection
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.efzzjcnpjigeffkiissb.supabase.co:5432/postgres

# JWT — generate: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=replace-with-64-char-random-hex

# CORS — no trailing slash
CORS_ORIGINS=http://localhost:3000,https://kartavya-aekam.vercel.app

# Web Push
VAPID_SUBJECT=mailto:admin@aekaminc.com

# Cookie security
COOKIE_SECURE=true
