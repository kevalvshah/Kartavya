# Kartavya Backend — Environment Variables
# Copy to .env for local dev, set in Railway for production

# Supabase PostgreSQL direct connection
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.efzzjcnpjigeffkiissb.supabase.co:5432/postgres

# JWT — generate: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=replace-with-64-char-random-hex

# CORS — no trailing slash
CORS_ORIGINS=http://localhost:3000,https://kartavaya.com,https://www.kartavaya.com
FRONTEND_URL=https://kartavaya.com

# Web Push
VAPID_SUBJECT=mailto:admin@aekaminc.com

# Email — set ONE of these:
# Option A (recommended): Resend — sign up at resend.com, verify aekaminc.com domain
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Option B: AWS SES
# AWS_ACCESS_KEY_ID=AKIAxxxxxxxxxxxxxxxx
# AWS_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# AWS_REGION=us-east-1
FROM_EMAIL=Kartavya <no-reply@aekaminc.com>

# Cookie security
COOKIE_SECURE=true
