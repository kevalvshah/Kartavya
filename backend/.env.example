# Kartavya by Aekam Inc — Backend env vars
# Copy to backend/.env for local dev
# Set all in Railway dashboard for production

MONGO_URL=mongodb://localhost:27017
DB_NAME=kartavya

# Generate: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=replace-with-64-char-random-hex

# No trailing slash — use Vercel subdomain for now
CORS_ORIGINS=http://localhost:3000,https://taskapp.vercel.app

COOKIE_SECURE=false
VAPID_SUBJECT=mailto:admin@aekaminc.com
