# Kartavya Backend — Environment Variables
# Copy to .env for local dev, set in Railway for production

# Supabase PostgreSQL direct connection
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.efzzjcnpjigeffkiissb.supabase.co:5432/postgres

# JWT — generate: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=replace-with-64-char-random-hex

# CORS — no trailing slash
CORS_ORIGINS=http://localhost:3000,https://kartavya-aekam.vercel.app

# Web Push
VAPID_SUBJECT=mailto:admin@aekaminc.com

# Email — set ONE of these:
# Option A (recommended): Resend — sign up at resend.com, verify kartavya.app domain
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Option B: AWS SES
# AWS_ACCESS_KEY_ID=AKIAxxxxxxxxxxxxxxxx
# AWS_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# AWS_REGION=us-east-1
FROM_EMAIL=Kartavya <hello@kartavya.app>

# WhatsApp (Meta Cloud API) — Phase 3
# Get from Meta Business Manager > WhatsApp > API Setup
WHATSAPP_PHONE_NUMBER_ID=1234567890123456
WHATSAPP_ACCESS_TOKEN=EAAxxxxxxxxxxxxxxxx
WHATSAPP_VERIFY_TOKEN=kartavya_webhook_verify   # arbitrary secret for webhook verification
WHATSAPP_APP_SECRET=abcdef1234567890abcdef      # Meta App Secret for HMAC-SHA256 (App Dashboard > Basic)

# Cookie security
COOKIE_SECURE=true
